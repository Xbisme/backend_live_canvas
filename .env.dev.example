# ---------------------------------------------------------------------------
# LiveCanvas backend — DEV flavor environment (example)
# Copy to `.env.dev` (git-ignored) and adjust. Run with:
#   DJANGO_SETTINGS_MODULE=config.settings.dev  (default in manage.py)
# ---------------------------------------------------------------------------

# Django secret key. Dev has a safe fallback; set your own to silence the warning.
SECRET_KEY=dev-insecure-change-me

# Database — matches docker-compose.yml (Postgres). Format: postgres://USER:PASS@HOST:PORT/NAME
DATABASE_URL=postgres://livecanvas:livecanvas@localhost:5432/livecanvas

# Comma-separated allowed hosts (dev is permissive by default).
ALLOWED_HOSTS=localhost,127.0.0.1

# Reserved for BE-002 app-tier auth — declared, NOT enforced in BE-001.
X_APP_KEY=dev-app-key

# Logging verbosity for the console handler.
DJANGO_LOG_LEVEL=DEBUG
