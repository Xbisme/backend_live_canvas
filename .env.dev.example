# ---------------------------------------------------------------------------
# LiveCanvas backend — DEV flavor environment (example)
# Copy to `.env.dev` (git-ignored) and adjust. Run with:
#   DJANGO_SETTINGS_MODULE=config.settings.dev  (default in manage.py)
# ---------------------------------------------------------------------------

# Django secret key. Dev has a safe fallback; set your own to silence the warning.
SECRET_KEY=dev-insecure-change-me

# Database — matches docker-compose.yml (Postgres). Format: postgres://USER:PASS@HOST:PORT/NAME
DATABASE_URL=postgres://livecanvas:livecanvas@localhost:5432/livecanvas

# Comma-separated allowed hosts (dev is permissive by default).
ALLOWED_HOSTS=localhost,127.0.0.1

# App-tier auth key (X-App-Key header) for public/IAP requests. Enforced in BE-002.
# An empty value denies all app-tier requests (fail-closed) — keep a dev key set.
X_APP_KEY=dev-app-key

# ---------------------------------------------------------------------------
# Object storage 2 vùng + CDN (BE-004). Dev dùng MinIO của docker-compose
# (docker compose up -d minio — bucket được minio-init tạo sẵn).
# Private = staging/masters (chỉ presigned); Public = thumbs/previews/covers (CDN).
# Bỏ trống toàn bộ để rơi về FileSystemStorage (chỉ đủ cho test không đụng media).
# ---------------------------------------------------------------------------
AWS_S3_ENDPOINT_URL=http://localhost:9000
AWS_STORAGE_BUCKET_NAME=livecanvas-private
AWS_PUBLIC_BUCKET_NAME=livecanvas-public
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
AWS_S3_REGION_NAME=us-east-1
CDN_BASE_URL=http://localhost:9000/livecanvas-public/

# ---------------------------------------------------------------------------
# Async media pipeline (BE-004): Celery broker + giới hạn upload.
# ---------------------------------------------------------------------------
CELERY_BROKER_URL=redis://localhost:6380/0   # compose maps host 6380 → container 6379
UPLOAD_MAX_BYTES=524288000

# Bulk backfill (BE-004, dev-only): thư mục dataset local chứa 397 video gốc.
BACKFILL_DATASET_DIR=/Users/you/Documents/database/crawl_script/livewallpapers

# Logging verbosity for the console handler.
DJANGO_LOG_LEVEL=DEBUG
