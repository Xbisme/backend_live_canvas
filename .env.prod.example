# ---------------------------------------------------------------------------
# LiveCanvas backend — PROD flavor environment (example)
# Copy to `.env.prod` (git-ignored) and set REAL values. Run with:
#   DJANGO_SETTINGS_MODULE=config.settings.prod
#
# On prod these values are REQUIRED (no defaults) — a missing SECRET_KEY,
# DATABASE_URL, ALLOWED_HOSTS, X_APP_KEY, or storage/CDN value makes startup fail
# fast (spec FR-011, FR-021).
# ---------------------------------------------------------------------------

# REQUIRED — strong random secret (e.g. `python -c "import secrets; print(secrets.token_urlsafe(64))"`).
SECRET_KEY=

# REQUIRED — managed Postgres. Format: postgres://USER:PASS@HOST:PORT/NAME
DATABASE_URL=

# REQUIRED — comma-separated production hostnames.
ALLOWED_HOSTS=api.example.com

# REQUIRED — app-tier key authenticating public/IAP requests (X-App-Key header).
# Prod refuses to boot if empty (fail-closed, FR-021).
X_APP_KEY=

# ---------------------------------------------------------------------------
# Object storage (S3-compatible) + CDN — REQUIRED in prod (config only in BE-002).
# Provider-agnostic: set AWS_S3_ENDPOINT_URL/REGION per provider (AWS S3 / R2 / Spaces).
# ---------------------------------------------------------------------------
# REQUIRED — private zone bucket (staging uploads + normalized masters; presigned-only).
AWS_STORAGE_BUCKET_NAME=
# REQUIRED (BE-004) — public zone bucket (thumbs/previews/covers; served via CDN).
AWS_PUBLIC_BUCKET_NAME=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# REQUIRED — public base URL the CDN serves public-zone objects from.
CDN_BASE_URL=
# Optional — set for non-AWS providers / custom endpoints and regions.
# Cloudflare R2: AWS_S3_ENDPOINT_URL=https://<account_id>.r2.cloudflarestorage.com
AWS_S3_ENDPOINT_URL=
AWS_S3_REGION_NAME=

# ---------------------------------------------------------------------------
# Async media pipeline (BE-004) — REQUIRED in prod.
# ---------------------------------------------------------------------------
# REQUIRED — managed Redis broker, e.g. redis://:PASS@HOST:6379/0
CELERY_BROKER_URL=
# Upload size ceiling in bytes (default 500 MB when unset).
UPLOAD_MAX_BYTES=524288000

# Logging verbosity for the JSON handler.
DJANGO_LOG_LEVEL=INFO
